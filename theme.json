{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": false,
			"customDuotone": false,
			"customGradient": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#f9f7f3",
					"name": "Neutral Pale",
					"slug": "custom-neutral-pale"
				},
				{
					"color": "#efeae2",
					"name": "Neutral Light",
					"slug": "custom-neutral-light"
				},
				{
					"color": "#3a382f",
					"name": "Grey Dark",
					"slug": "custom-grey-dark"
				},
				{
					"color": "#1e1b15",
					"name": "Black",
					"slug": "custom-black"
				},
				{
					"color": "#7a3b2e",
					"name": "Accent",
					"slug": "custom-accent"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "custom-white"
				}
			]
		},
		"layout": {
			"contentSize": "620px",
			"wideSize": "1000px"
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "3x Small",
					"size": "0.175rem",
					"slug": "10"
				},
				{
					"name": "2x Small",
					"size": "0.25rem",
					"slug": "20"
				},
				{
					"name": "X Small",
					"size": "0.5rem",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "min(0.75rem, 1vw)",
					"slug": "40"
				},
				{
					"name": "Medium",
					"size": "min(1.5rem, 2vw)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "min(2.25rem, 3vw)",
					"slug": "60"
				},
				{
					"name": "X Large",
					"size": "min(3rem, 4vw)",
					"slug": "70"
				},
				{
					"name": "2x Large",
					"size": "min(4.5rem, 6vw)",
					"slug": "80"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "\"Inter Tight\"",
							"fontStyle": "normal",
							"fontWeight": "200",
							"src": [
								"file:./assets/fonts/inter-tight/inter-tight-200-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Inter Tight\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/inter-tight/inter-tight-400-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Inter Tight\"",
							"fontStyle": "italic",
							"fontWeight": "200",
							"src": [
								"file:./assets/fonts/inter-tight/inter-tight-200-italic.woff2"
							]
						},
						{
							"fontFamily": "\"Inter Tight\"",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/inter-tight/inter-tight-400-italic.woff2"
							]
						}
					],
					"fontFamily": "\"Inter Tight\", sans-serif",
					"name": "Inter Tight",
					"slug": "inter-tight"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--custom-neutral-pale)",
			"text": "var(--wp--preset--color--custom-black)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--custom-black)",
					"text": "var(--wp--preset--color--custom-white)"
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--custom-grey-dark)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--custom-black)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter-tight)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--custom-accent)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--custom-accent)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter-tight)",
			"fontStyle": "normal",
			"fontWeight": "200"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	]
}